  "paths": {
    "/": {
      "get": {
        "operationId": "authentication",
        "tags": [
          "Autenticaci\u00f3n",
          "Authentication"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Cabecera de autorizaci\u00f3n a la que debes a\u00f1adir tu API Key.",
            "x-description-i18n": {
              "eng": "Authorization header containing your API key."
            },
            "required": true,
            "example": "Basic RXN0YUVzVHVBUElLZXlNYW50ZW5sYVNlZ3VyYQ==",
            "x-example-i18n": {
              "eng": "Basic VGhpc0lzWW91ckFQSUtleUtlZXBJdFNhZmU="
            },
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "code": 200,
                      "message": "OK",
                      "current_time": "2019-05-30T12:55:48+0200"
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ResponseOK"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "code": 400,
                      "message": "Bad Request",
                      "details": "<service> parameter is not valid. Please, review documentation."
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ResponseKO"
                }
              }
            },
            "description": "Bad request"
          },
          "403": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "code": 403,
                      "message": "Forbidden",
                      "current_time": "2019-05-30T12:55:48+0200"
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ResponseKO"
                }
              }
            },
            "description": "Forbidden"
          }
        },
        "summary": "Autenticaci\u00f3n de peticiones",
        "description": "Ejemplo de como autenticar todas las peticiones a la API.",
        "x-description-i18n": {
          "eng": "API Request authentication example."
        },
        "x-summary-i18n": {
          "eng": "Request authentication"
        }
      }
    },
    "/api-key/me": {
      "get": {
        "operationId": "my-api-key-profiles",
        "tags": [
          "API Keys"
        ],
        "parameters": [
          {
            "$ref": "#/paths/~1/get/parameters/0"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "code": 200,
                      "current_time": "2019-05-30T12:55:48+0200",
                      "message": "OK",
                      "profiles": [
                        "payment",
                        "readonly",
                        "tokenize",
                        "batch_authorization",
                        "keyentry"
                      ]
                    }
                  }
                },
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ResponseOK"
                    },
                    {
                      "properties": {
                        "profiles": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/APIKeyProfile"
                          },
                          "description": "Todos los perfiles de API key a los que tiene acceso el cliente que ha realizado la petici\u00f3n.",
                          "x-description-i18n": {
                            "eng": "Every profile this API key has access to."
                          }
                        }
                      },
                      "required": [
                        "profiles"
                      ]
                    }
                  ]
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Ver los perfiles de mi API key",
        "description": "Este endpoint sirve para obtener los perfiles de la API key que se ha usado en la petici\u00f3n. Si la API key tiene acceso total, se devolver\u00e1 el perfil `all`.",
        "x-description-i18n": {
          "eng": "This endpoint returns the profiles of the API key that was used in the request. If the API key has total access, it will return `all`."
        },
        "x-summary-i18n": {
          "eng": "View my API key profiles"
        }
      }
    },
    "/api-key/profiles": {
      "get": {
        "operationId": "api-key-profiles",
        "tags": [
          "API Keys"
        ],
        "parameters": [
          {
            "$ref": "#/paths/~1/get/parameters/0"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "code": 200,
                      "current_time": "2019-05-30T12:55:48+0200",
                      "message": "OK",
                      "profiles": [
                        "payment",
                        "refund",
                        "readonly",
                        "card",
                        "tokenize",
                        "moto",
                        "batch_authorization",
                        "batch_refund",
                        "keyentry"
                      ]
                    }
                  }
                },
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ResponseOK"
                    },
                    {
                      "properties": {
                        "profiles": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/APIKeyProfile"
                          },
                          "description": "Todos los perfiles de API key existentes.",
                          "x-description-i18n": {
                            "eng": "All existing API profiles."
                          }
                        }
                      }
                    }
                  ]
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Obtener perfiles API key",
        "description": "Este endpoint sirve para obtener todos los perfiles que puede tener una API key.\n* `all`: Acceso total\n* `payment`: Creaci\u00f3n de \u00f3rdenes, pagos, devoluciones, confirmaciones, cancelaciones, tokenizaci\u00f3n de tarjetas\n* `refund`: Devolver \u00f3rdenes.\n* `readonly`: Leer \u00f3rdenes, clientes, tarjetas, etc,\n* `card`: Tokenizar, listar, modificar y borrar tarjetas\n* `tokenize`: Tokenizar tarjetas\n* `moto`: Lanzar campa\u00f1as MoTo\n* `batch_authorization`: Lanzar pagos en lote\n* `batch_refund`: Lanzar devoluciones en lote\n* `keyentry`: Procesar pagos manuales",
        "x-description-i18n": {
          "eng": "This endpoint returns all the profiles that an API key can have.\n* `all`: Full access\n* `payment`: Order creation, payment, refunds, confirmation and cancellation, card tokenization\n* `refund`: Refunding orders.\n* `readonly`: Reading orders, customers, cards, etc\n* `card`: Tokenizing, listing, modifying and deleting cards\n* `tokenize`: Card tokenization\n* `moto`: Uploading MoTo campaigns\n* `batch_authorization`: Uploading batches of payments\n* `batch_refund`: Uploading batches of refunds\n* `keyentry`: Processing manual payments"
        },
        "x-summary-i18n": {
          "eng": "View the profiles of my API key"
        }
      }
    },
    "/batch/authorizations": {
      "post": {
        "operationId": "batch-payments-file",
        "tags": [
          "Operaciones en lote",
          "Batch operations"
        ],
        "parameters": [
          {
            "$ref": "#/paths/~1/get/parameters/0"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "string",
                    "description": "Fichero CSV codificado en base64.",
                    "x-description-i18n": {
                      "eng": "CSV file encoded in base64."
                    }
                  },
                  "execute_at": {
                    "type": "string",
                    "description": "Fecha a partir de la cual se procesar\u00e1 el fichero. Si no se especifica esta fecha, el fichero se encolar\u00e1 para su procesado en el momento del env\u00edo.",
                    "nullable": true,
                    "x-description-i18n": {
                      "eng": "Date after which the file will be processed. If this date is not specified, the file will be queued for processing as soon as it is uploaded."
                    }
                  },
                  "filename": {
                    "type": "string",
                    "description": "Nombre del fichero bajo el que se agrupar\u00e1n los pagos enviados.",
                    "x-description-i18n": {
                      "eng": "Name of the file under which the payments will be grouped."
                    }
                  },
                  "signature": {
                    "$ref": "#/paths/~1user/post/requestBody/content/application~1json/schema/properties/signature"
                  }
                },
                "example": {
                  "data": "QU1PVU5ULENBUkQsQ1VTVE9NRVJfRVhURVJOQUxfSUQsU0VSVklDRSxBRERJVElPTkFMLFVSTF9QT1NUDQoxMjAzNSxFNzZBNTdGRi00REJDLTRBM0QtQjZFMy0wNTIwRThCMTNFM0YsMzA4LDExNEFCNDI0LTAyM0ItNEUxMy",
                  "execute_at": "2017-11-11 11:11:11",
                  "filename": "test.csv",
                  "signature": "121149a0ba5361191d740fa898784a8b"
                },
                "required": [
                  "signature",
                  "filename",
                  "data"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "message": "OK",
                      "code": 200,
                      "current_time": "2017-10-26T17:28:06+0200"
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ResponseOK"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "message": "Bad Request",
                      "code": 400,
                      "errors": [
                        {
                          "line": 1,
                          "msg": "<amount> parameter is not numeric. Ex: 100 for 1.00 \u20ac"
                        }
                      ]
                    }
                  }
                },
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ResponseKO"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "errors": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/BatchError"
                          },
                          "description": "Lista los errores producidos en cada una de las l\u00edneas del fichero. Si no hay ning\u00fan error, esta clave no se devuelve.",
                          "x-description-i18n": {
                            "eng": "Lists the errors occurred in each line of the file. If there are no errors, this key will not be returned."
                          }
                        }
                      }
                    }
                  ]
                }
              }
            },
            "description": "Bad Request"
          },
          "422": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "message": "Unprocessable Entity",
                      "code": 422,
                      "details": "Invalid header: missing header: amount"
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ResponseKO"
                }
              }
            },
            "description": "Unprocessable Entity"
          }
        },
        "summary": "Fichero de pagos",
        "description": "Encola un fichero de pagos en batch.",
        "x-description-i18n": {
          "eng": "Queues a payment batch file."
        },
        "x-summary-i18n": {
          "eng": "Payments file"
        }
      }
    },
