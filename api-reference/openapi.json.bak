                    }
                  },
                  "mid": {
                    "type": "string",
                    "description": "Identificador del comercio.",
                    "x-description-i18n": {
                      "eng": "Merchant identifier."
                    }
                  },
                  "stan": {
                    "type": "string",
                    "description": "Identificador de la operaci\u00f3n utilizado para la trazabilidad de la misma.",
                    "x-description-i18n": {
                      "eng": "Transaction identifier used to trace its transactional flow."
                    }
                  },
                  "card_reading_method": {
                    "type": "string",
