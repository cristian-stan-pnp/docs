{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Documentaci\u00f3n de Paylands",
    "contact": {
      "name": "Alguna pregunta? Contacta con nosotros aqu\u00ed",
      "email": "soporte@paylands.com"
    },
    "x-logo": {
      "url": "https://paylands-web-assets.s3.eu-west-1.amazonaws.com/logos/documentation-paylands-logo.png",
      "backgroundColor": "#FFFFFF",
      "altText": "Referencia API Paylands"
    }
  },
  "servers": [
    {
      "url": "https://api.paylands.com/v1/sandbox",
