                      "eng": "Defines how the card has been provided."
                    }
                  },
                  "emv_data": {
                    "type": "string",
                    "description": "Datos cifrados con informaci\u00f3n de la tarjeta y de la transacci\u00f3n.",
                    "x-description-i18n": {
                      "eng": "Encrypted data including card and transaction information."
                    }
                  },
                  "card_sequence_number": {
                    "type": "string",
