        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "signature": {
                    "$ref": "#/paths/~1user/post/requestBody/content/application~1json/schema/properties/signature"
                  },
                  "card": {
                    "type": "object",
                    "description": "Si se env\u00eda el campo track2, los campos pan, expiration_month y expiration_year no se deber\u00e1n incluir. Si no se env\u00eda el track2, los campos pan, expiration_month y expiration_year son obligatorios.",
                    "x-description-i18n": {
                      "eng": "If the track2 field is provided, the pan, expiration_month, and expiration_year fields must not be included. If track2 is not sent, the pan, expiration_month, and expiration_year fields are mandatory."
                    },
                    "properties": {
                      "pan": {
                        "type": "string",
                        "description": "PAN cifrado",
                        "x-description-i18n": {
                          "eng": "Encrypted PAN"
                        },
                        "nullable": true
                      },
                      "expiration_month": {
                        "type": "string",
                        "description": "Mes de caducidad de la tarjeta",
                        "x-description-i18n": {
                          "eng": "Card's expiration month"
                        },
                        "nullable": true
                      },
                      "expiration_year": {
                        "type": "string",
                        "description": "A\u00f1o de caducidad de la tarjeta",
                        "x-description-i18n": {
                          "eng": "Card's expiration year"
                        },
                        "nullable": true
                      },
                      "track2": {
                        "type": "string",
                        "description": "Datos cifrados que contienen la informaci\u00f3n del PAN y fecha de caducidad",
                        "x-description-i18n": {
                          "eng": "Encrypted string containing PAN and expiration date"
                        },
                        "nullable": true
                      }
                    }
                  },
                  "amount": {
                    "$ref": "#/components/schemas/Plan/properties/amount"
                  },
                  "currency": {
                    "type": "string",
                    "example": "EUR",
                    "description": "C\u00f3digo de 3 letras identificando la moneda utilizada.",
                    "x-description-i18n": {
                      "eng": "3 letter currency code."
                    }
                  },
                  "mid": {
                    "$ref": "#/paths/~1card-present~1charge/post/requestBody/content/application~1json/schema/properties/mid"
                  },
                  "stan": {
                    "$ref": "#/paths/~1card-present~1charge/post/requestBody/content/application~1json/schema/properties/stan"
                  },
                  "card_reading_method": {
                    "$ref": "#/paths/~1card-present~1charge/post/requestBody/content/application~1json/schema/properties/card_reading_method"
                  },
                  "emv_data": {
                    "$ref": "#/paths/~1card-present~1charge/post/requestBody/content/application~1json/schema/properties/emv_data"
                  },
                  "card_sequence_number": {
                    "$ref": "#/paths/~1card-present~1charge/post/requestBody/content/application~1json/schema/properties/card_sequence_number"
                  },
                  "pin": {
                    "type": "object",
                    "properties": {
                      "cryptogram": {
                        "type": "string",
                        "description": "PIN cifrado",
                        "x-description-i18n": {
                          "eng": "Encrypted PIN number"
                        }
                      },
                      "format": {
                        "type": "string",
                        "enum": [
                          "ISO-0",
                          "ISO-1"
                        ],
                        "description": "Indica cual de los estandares de codificaci\u00f3n del PIN se ha utilizado",
                        "x-description-i18n": {
                          "eng": "Which one of the encoding standards has been used"
