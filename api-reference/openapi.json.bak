                          "eng": "Which one of the encoding standards has been used"
                        }
                      },
                      "ksn": {
                        "type": "string",
                        "description": "Identificador de la clave de cifrado utilizada",
                        "x-description-i18n": {
                          "eng": "Encryption key identifier"
                        }
                      }
                    }
                  },
                  "device": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "description": "Indica el tipo de dispositivo utilizado",
                        "x-description-i18n": {
                          "eng": "Device type"
