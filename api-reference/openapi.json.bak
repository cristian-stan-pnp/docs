            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "response": {
                    "value": {
                      "amount": 1,
                      "attempt": 1,
                      "company": "FF255421-F4B7-47E9-9816-949F5F03DE6F",
                      "currency": "978",
                      "customer": "customer_external_id",
                      "payment_date": "2019-12-18T10:34:12.640Z",
                      "payment_id": "5dfa00a4229c1a127749ae9e",
                      "payment_number": 1,
                      "plan": "plan_external_id",
                      "product": "product_external_id",
                      "status": "PAID",
                      "subscription": "5dfa00a4229c1a127749ae9d"
                    }
                  }
                },
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "properties": {
                        "amount": {
                          "$ref": "#/components/schemas/Plan/properties/amount"
                        },
                        "attempt": {
                          "$ref": "#/components/schemas/SubscriptionPayment/properties/attempt"
                        },
                        "company": {
                          "type": "string",
                          "description": "ID externo otorgado por el comercio para identificar de forma \u00fanica a una compa\u00f1\u00eda.",
                          "x-description-i18n": {
                            "eng": "External ID provided by the merchant to uniquely identify a company."
                          }
                        },
                        "currency": {
                          "$ref": "#/paths/~1card-present~1charge/post/responses/200/content/application~1json/schema/allOf/1/properties/order/properties/currency"
                        },
                        "customer": {
                          "$ref": "#/components/schemas/Customer/properties/external_id"
                        },
                        "payment_date": {
                          "$ref": "#/components/schemas/SubscriptionPayment/properties/payment_date"
                        },
                        "payment_id": {
                          "$ref": "#/components/schemas/SubscriptionPayment/properties/id"
                        },
                        "payment_number": {
                          "$ref": "#/components/schemas/SubscriptionPayment/properties/payment_number"
                        },
                        "plan": {
                          "$ref": "#/components/schemas/Plan/properties/external_id"
                        },
                        "product": {
                          "$ref": "#/components/schemas/Product/properties/external_id"
                        },
                        "status": {
                          "$ref": "#/components/schemas/SubscriptionStatus"
                        },
