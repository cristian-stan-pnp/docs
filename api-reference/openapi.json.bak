    "/payment-method/card/batch": {
      "post": {
        "operationId": "save-cards",
        "tags": [
          "Tarjetas",
          "Cards"
        ],
        "parameters": [
          {
            "$ref": "#/paths/~1/get/parameters/0"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "signature": {
                    "$ref": "#/paths/~1user/post/requestBody/content/application~1json/schema/properties/signature"
                  },
                  "cards": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "card_holder": {
                          "$ref": "#/components/schemas/Card/properties/holder"
                        },
                        "card_pan": {
                          "$ref": "#/paths/~1charge/post/requestBody/content/application~1json/schema/properties/card_pan"
                        },
                        "card_expiry_month": {
                          "$ref": "#/components/schemas/Card/properties/expire_month"
                        },
                        "card_expiry_year": {
                          "$ref": "#/components/schemas/Card/properties/expire_year"
                        },
                        "customer_ext_id": {
                          "$ref": "#/components/schemas/Customer/properties/external_id"
                        },
                        "additional": {
                          "$ref": "#/paths/~1payment~1moto~1json/post/requestBody/content/application~1json/schema/properties/payments/items/properties/additional",
                          "nullable": true
                        },
                        "url_post": {
                          "$ref": "#/paths/~1payment~1moto~1json/post/requestBody/content/application~1json/schema/properties/payments/items/properties/url_post",
                          "nullable": true
                        },
                        "validate": {
                          "type": "boolean",
                          "default": false,
                          "description": "S\u00f3lo necesario si se quiere validar la tarjeta. Si se env\u00eda, el campo `service` es obligatorio, y el campo `card_cvv` puede enviarse para validar tambi\u00e9n el CVV.",
                          "nullable": true,
                          "x-description-i18n": {
                            "eng": "Only necessary if you want the card to be validated. If provided, the `service` field becomes required, and the `card_cvv` field may be sent to validate it as well."
                          }
                        },
                        "service": {
                          "$ref": "#/components/schemas/Order/properties/service_uuid",
                          "nullable": true
                        },
                        "card_cvv": {
                          "$ref": "#/paths/~1payment~1moto/post/requestBody/content/application~1json/schema/properties/card_cvv",
                          "nullable": true
                        }
                      },
                      "required": [
                        "card_holder",
                        "card_pan",
                        "card_expiry_month",
                        "card_expiry_year",
                        "customer_ext_id"
                      ]
                    },
                    "description": "Lista de tarjetas a tokenizar.",
                    "x-description-i18n": {
                      "eng": "List of cards to tokenize."
                    }
                  }
                },
                "example": {
                  "signature": "121149a0ba5361191d740fa898784a8b",
                  "cards": [
                    {
                      "card_holder": "John Doe",
                      "card_pan": "4111111111111111",
                      "card_expiry_month": "12",
                      "card_expiry_year": "19",
                      "customer_ext_id": "user",
                      "additional": "card12345",
                      "url_post": "https://www.some.url",
                      "validate": true,
                      "service": "4D1DA790-B361-4657-BFB7-E2988F4527A4",
                      "card_cvv": "123"
                    },
                    {
                      "card_holder": "Pepe",
                      "card_pan": "4918019160034602",
                      "card_expiry_month": "10",
                      "card_expiry_year": "23",
                      "customer_ext_id": "user2",
                      "additional": "Tarjeta principal",
                      "url_post": "https://www.some.url"
                    }
                  ]
                },
                "required": [
                  "signature",
                  "cards"
                ]
              }
            }
          }
        },
        "responses": {
