                    "type": "object",
                    "description": "Si se env\u00eda el campo track2, los campos pan, expiration_date, expiration_month y expiration_year no se deber\u00e1n incluir. Si no se env\u00eda el track2, el campo pan es obligatorio. Adem\u00e1s, tambi\u00e9n ser\u00e1 requerido enviar o bien expiration_date en formato yyMM o los campos expiration_month y expiration_year.",
                    "x-description-i18n": {
                      "eng": "If the track2 field is sent, the fields pan, expiration_date, expiration_month, and expiration_year must not be included. If track2 is not sent, the pan field is mandatory. Additionally, either expiration_date in yyMM format or the fields expiration_month and expiration_year must also be provided."
                    },
                    "properties": {
                      "pan": {
                        "type": "string",
                        "description": "PAN cifrado. S\u00f3lo si no se indica track2.",
                        "x-description-i18n": {
                          "eng": "Encrypted PAN. Only if track2 is not provided."
                        },
                        "nullable": true
                      },
                      "expiration_date": {
                        "type": "string",
                        "description": "Fecha de caducidad de la tarjeta en formato yyMM y cifrado. S\u00f3lo si no se indica track2.",
                        "x-description-i18n": {
                          "eng": "Card's expiration date in yyMM format. It must be encrypted. Only if track2 is not provided."
                        },
                        "nullable": true
                      },
                      "ksn": {
                        "type": "string",
                        "description": "KSN utilizado para cifrar el campo expiration_date si se proporciona.",
                        "x-description-i18n": {
                          "eng": "KSN that has been used to encrypt the corresponding fields (track2 or pan+expiration_date)"
                        },
                        "nullable": true
                      },
                      "track2": {
                        "type": "string",
                        "description": "Datos cifrados que contienen la informaci\u00f3n del PAN y fecha de caducidad. S\u00f3lo si no se indica pan ni expiration_date",
                        "x-description-i18n": {
                          "eng": "Encrypted string containing PAN and expiration date. Only if pan+expiration_date are not provided."
                        },
                        "nullable": true
                      }
                    }
