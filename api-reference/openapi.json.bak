    "/payment/bizum/{token}": {
      "get": {
        "operationId": "bizum-payment",
        "tags": [
          "Pagos",
          "Payments"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "example": "ebc9b5ffa2efcf74197734a071192817e6f2a3fc15f49c4b1bdb6edc46b16e3ab4109498bff8e6ba00fb6d2bd1838afbea67095c4caaa2f46e4acf4d5851884c",
            "schema": {
              "type": "string"
            },
            "description": "El token de la orden.",
            "x-description-i18n": {
              "eng": "The token of the order."
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/html": {
                "examples": {
                  "response": {
                    "value": ""
                  }
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Bizum",
        "description": "El usuario es redirigido a la p\u00e1gina de pago de Bizum, donde deber\u00e1 introducir el n\u00famero de tel\u00e9fono de la cuenta desde donde desea pagar.\n\nEsta modalidad de pago solo est\u00e1 disponible en REDSYS y ser\u00e1 necesario activarlo previamente: p\u00f3ngase en contacto con soporte para activar esta configuraci\u00f3n.\n\nEn el entorno SANDBOX, se puede simular pagos exitosos o rechazados utilizando los siguientes valores como n\u00famero de tel\u00e9fono, cuando se solicite:\n- Pago exitoso: `700000000`\n- Pago rechazado: `ko@ko.ko`",
        "x-description-i18n": {
          "eng": "The user is redirected to the Bizum payment page, where they must enter the phone number of the account from which they wish to pay.\n\nThis payment method is only available in REDSYS and it will be necessary to activate it previously: contact support to activate this configuration.\n\nIn SANDBOX environment, successful and refused payments can be simulated by entering the following values when the payment process asks for the phone number:\n- Successful payment: `700000000`\n- Refused payment: `ko@ko.ko`"
        },
        "x-summary-i18n": {
          "eng": "Bizum"
        }
      }
    },
