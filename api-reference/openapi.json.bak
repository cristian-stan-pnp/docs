          "Subscriptions"
        ],
        "parameters": [
          {
            "$ref": "#/paths/~1/get/parameters/0"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "signature": {
                    "$ref": "#/paths/~1user/post/requestBody/content/application~1json/schema/properties/signature"
                  },
                  "plan": {
                    "$ref": "#/components/schemas/Plan/properties/external_id"
                  },
                  "customer": {
                    "$ref": "#/components/schemas/Customer/properties/external_id"
                  },
                  "additional_data": {
                    "$ref": "#/components/schemas/Subscription/properties/additional_data"
                  },
                  "total_payment_number": {
                    "$ref": "#/components/schemas/Subscription/properties/total_payment_number"
                  },
                  "payment_attempts_limit": {
                    "type": "number",
                    "description": "N\u00famero m\u00e1ximo de intentos para cobrar una suscripci\u00f3n. Si el cobro de una suscripci\u00f3n falla X veces consecutivas, la suscripci\u00f3n se cancela.",
                    "x-description-i18n": {
                      "eng": "Maximum amount of retries to charge for any subscription payment. If the payment fails X times consecutively, the subscription is cancelled."
                    }
                  },
                  "initial_date": {
                    "type": "string",
                    "description": "Por defecto es la fecha actual. Si se indica permite especificar el momento en el que se realizar\u00e1 el primer pago.",
                    "nullable": true,
                    "x-description-i18n": {
                      "eng": "By default, the current date. If provided it specifies when the first payment will be performed."
                    }
                  }
                },
                "example": {
                  "signature": "121149a0ba5361191d740fa898784a8b",
                  "customer": "customer name",
                  "plan": "plan",
                  "additional_data": {
                    "additional": "Datos extra",
                    "customer_ext_id": "customer322",
                    "operative": "AUTHORIZATION",
                    "service": "60A1F4C0-CC58-47A9-A0B9-868F9EF29045",
                    "source_uuid": "C10721E7-1404-45DC-8762-351DD9945D1D",
                    "url_post": "https://yourdomain.com/subscriptions/notify"
                  },
                  "initial_date": "2019",
                  "payment_attempts_limit": 3,
