                    "value": {
                      "code": 303,
                      "details": "https://api.paylands.com/v1/sandbox/payment/process/0778dcd0e8725d6cab189df0ec794017f96bd54049c5d3c660db776dabfda69b2498d85756eb8edd0f6384c719ac85e97ec119e6a56ebad8722fafb34f66aebf?apm=BIZUM",
                      "message": "See Other"
