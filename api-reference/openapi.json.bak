                "examples": {
                  "response": {
                    "value": {
                      "code": 303,
                      "details": "https://api.paylands.com/v1/payment/tokenized/082a593dcccf5f3f37a563815659d4316154dff7f8139fabaa98bdffe9ce4375c5f9bb60825d1585738",
                      "message": "See Other"
                    }
                  }
