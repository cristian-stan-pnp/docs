        ],
        "parameters": [
          {
            "$ref": "#/paths/~1/get/parameters/0"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "signature": {
                    "type": "string",
                    "description": "Firma que acompa\u00f1a a la API key. Requerida en todas las peticiones POST/PUT/DELETE.",
                    "x-description-i18n": {
                      "eng": "Signature paired with the API key. Required in all POST/PUT/DELETE requests."
                    }
                  },
                  "email": {
                    "type": "string",
                    "description": "Correo electr\u00f3nico del usuario.",
                    "x-description-i18n": {
                      "eng": "Email of the customer."
                    }
                  },
                  "username": {
                    "type": "string",
                    "description": "Nombre del usuario",
                    "x-description-i18n": {
                      "eng": "User's name."
                    }
                  },
                  "language": {
                    "type": "string",
                    "enum": [
                      "ES",
                      "EN",
                      "PT"
                    ],
                    "description": "Idioma por defecto en que se mostrar\u00e1 el panel al usuario",
                    "x-description-i18n": {
                      "eng": "User's default language that will be used when accessing the control panel"
                    }
                  },
                  "environment": {
                    "type": "string",
                    "enum": [
                      "SANDBOX",
                      "PRODUCTION"
                    ],
                    "description": "Entorno por defecto donde acceder\u00e1 el usuario.",
                    "x-description-i18n": {
                      "eng": "User's default environment."
                    }
                  },
                  "send_email_with_credentials": {
                    "type": "boolean",
                    "description": "Indica si, tras crear el usuario, se le enviar\u00e1 un mail con los datos de acceso al panel",
                    "x-description-i18n": {
                      "eng": "Whether an email containing login details must be sent or not"
                    }
                  },
                  "group": {
                    "type": "string",
                    "enum": [
                      "MANAGER",
                      "USER",
                      "VIEWER",
                      "MANUAL PAYMENT",
                      "BATCH",
                      "PAYMENTS"
                    ],
                    "description": "* MANAGER: acceso a todas las secciones de visualizaci\u00f3n y configuraci\u00f3n\n* USER: puede ver las operaciones, terminales y servicios\n* VIEWER: puede ver las operaciones y pagos MoTo\n* MANUAL PAYMENT: puede crear pagos manuales y ver las operaciones\n* BATCH: tiene acceso a los pagos batch (creaci\u00f3n y listado)\n* PAYMENTS: acceso a todos los tipos de pago desde el panel, visualizaci\u00f3n de las \u00f3rdenes de pago y listado de tarjetas (sin datos sensibles)",
                    "x-description-i18n": {
                      "eng": "* MANAGER: has access to all sections, including reporting and configuration ones\n* USER: has access to transactions, terminals and payment services\n* VIEWER: can visualize transactions and MoTo payments\n* MANUAL PAYMENT: can execute manual payments and visualize transactions\n* BATCH: can process and list batch payments\n* PAYMENTS: has access to all transactions and cards list (no sensitive data is exposed)"
                    }
                  }
                },
                "example": {
                  "signature": "121149a0ba5361191d740fa898784a8b",
                  "email": "email@email.com",
                  "username": "John",
                  "language": "ES",
                  "environment": "SANDBOX",
                  "send_email_with_credentials": false,
                  "group": "MANAGER"
                },
                "required": [
                  "signature",
                  "email",
                  "username",
                  "language",
                  "environment",
                  "group",
